HOST=0.0.0.0
PORT=8787
BORE_SERVER_ORIGIN=https://bore.dk
BORE_WEB_ORIGIN=https://bore.dk
BORE_PUBLIC_DOMAIN=bore.dk
BORE_TOKEN_SECRET=replace-with-a-long-random-secret
BORE_DB_PATH=/data/bore.sqlite
BORE_CONTROL_PLANE_ORIGIN=http://bore-control-plane:8787
BORE_TRAEFIK_ENABLED=true
BORE_TRAEFIK_DYNAMIC_DIR=/runtime/traefik-dynamic
BORE_TRAEFIK_SERVICE_NAME=bore-service
BORE_TRAEFIK_CERTIFICATE_RESOLVER=letsencrypt
TRAEFIK_ACME_EMAIL=john@example.com
