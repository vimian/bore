{
  "name": "bore",
  "private": true,
  "version": "0.1.0",
  "license": "BUSL-1.1",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r --filter ./apps/* build",
    "dev:agent": "pnpm --filter @bore/agent dev",
    "dev:server": "pnpm --filter @bore/control-plane dev",
    "dev:web": "pnpm --filter web dev",
    "user:set-limit": "tsx scripts/set-user-limit.ts",
    "user:set-access-host-limit": "tsx scripts/set-user-access-host-limit.ts",
    "test": "pnpm -r --if-present --filter ./apps/* test",
    "typecheck": "pnpm -r --filter ./apps/* typecheck"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0"
  }
}
